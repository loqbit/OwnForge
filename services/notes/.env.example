APP_ENV=development
SERVER_PORT=8080
GRPC_SERVER_PORT=9093

# Postgres (used by docker-compose to build DATABASE_SOURCE)
POSTGRES_USER=ownforge
POSTGRES_PASSWORD=change-me
POSTGRES_DB=go_note

# If running outside compose, override with a full DSN:
# DATABASE_SOURCE=postgres://user:pass@host:5432/db?sslmode=disable
DATABASE_DRIVER=postgres
DATABASE_AUTO_MIGRATE=false

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=change-me
REDIS_DB=0

ID_GENERATOR_ADDR=localhost:50059
IDENTITY_ADDR=localhost:9091

OTEL_JAEGER_ENDPOINT=localhost:4318
OTEL_SERVICE_NAME_HTTP=go-note-http
OTEL_SERVICE_NAME_GRPC=go-note-grpc

METRICS_PORT=9094

# MinIO
MINIO_ACCESS_KEY=ownforge
MINIO_SECRET_KEY=change-me

# AI (ai-worker)
AI_PROVIDER=openai            # anthropic | openai | ollama | qwen
AI_BASE_URL=
AI_API_KEY=
AI_ENRICH_MODEL=
AI_REPORT_MODEL=
AI_MAX_TOKENS=1024
AI_WORKER_COUNT=4
AI_MIN_CONTENT_LEN=50
