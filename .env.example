# Root docker-compose configuration. Copy to .env and fill in.
APP_ENV=development

# ─── Postgres ────────────────────────────────────────────────────────
POSTGRES_USER=ownforge
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ownforge

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me

# ─── Auth ────────────────────────────────────────────────────────────
# 32+ char random string. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-a-real-secret

# ─── Object storage (MinIO) ──────────────────────────────────────────
MINIO_ACCESS_KEY=ownforge
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=ownforge-notes
# Host-side ports (MinIO inside the container always listens on 9000/9001).
# Change if you already have something on 9000 (e.g. OrbStack).
MINIO_API_PORT=9100
MINIO_CONSOLE_PORT=9101

# ─── Gateway ─────────────────────────────────────────────────────────
GATEWAY_PORT=8000

# ─── AI worker (only needed with --profile ai) ───────────────────────
AI_PROVIDER=openai
AI_BASE_URL=
AI_API_KEY=
AI_ENRICH_MODEL=
AI_REPORT_MODEL=
AI_MAX_TOKENS=1024
AI_WORKER_COUNT=4
AI_MIN_CONTENT_LEN=50
